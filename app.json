{
  "expo": {
    "name": "LawCosmosAI",
    "slug": "LawcosmosAI",
    "version": "1.0.1",
    "description": "Bangla-first legal information for Bangladesh: ask a question, see the applicable law with citation, the exact penalty, and next steps. Legal information, not legal advice.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lawcosmosai",
    "userInterfaceStyle": "light",
    "primaryColor": "#C65D3B",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lawcosmosai.app"
    },
    "android": {
      "package": "com.lawcosmosai.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#C65D3B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "LawCosmosAI — আইন জানুন, খরচ জানুন",
      "shortName": "LawCosmosAI",
      "themeColor": "#FAF9F5",
      "backgroundColor": "#FAF9F5",
      "output": "single"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAF9F5"
        }
      ],
      "expo-font"
    ]
  }
}
