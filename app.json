{
  "expo": {
    "name": "LawCosmosAI",
    "slug": "LawcosmosAI",
    "version": "1.0.6",
    "description": "Bangla-first legal information for Bangladesh: ask a question, see the applicable law with citation, the exact penalty, and next steps. Legal information, not legal advice. Built by The Mavericks.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lawcosmosai",
    "userInterfaceStyle": "light",
    "primaryColor": "#0F5D44",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lawcosmosai.app"
    },
    "android": {
      "package": "com.lawcosmosai.app",
      "versionCode": 7,
      "adaptiveIcon": {
        "backgroundColor": "#0B4A38",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "LawCosmosAI — আইন জানুন, খরচ জানুন",
      "shortName": "LawCosmosAI",
      "themeColor": "#F4F7F3",
      "backgroundColor": "#F4F7F3",
      "output": "single"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F4F7F3"
        }
      ],
      "expo-font"
    ]
  }
}
